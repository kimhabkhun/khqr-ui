{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* IMPORTANT for library */
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "./src",
    /* React */
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "isolatedModules": true,
    "noEmit": false,
    "strict": true
  },
  "include": ["src"]
}